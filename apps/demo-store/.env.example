# Glassbox Demo Store — runtime configuration
#
# The tracker API key + endpoint are read at RUNTIME via /api/config, so a
# deployed Cloud Run service can set them via env without a rebuild.
#
# Preferred (server-only, read at runtime):
GLASSBOX_API_KEY=
GLASSBOX_ENDPOINT=http://localhost:3000

# Local-dev fallbacks (used only if the server vars above are unset):
# NEXT_PUBLIC_GLASSBOX_API_KEY=gb_live_xxx
# NEXT_PUBLIC_GLASSBOX_ENDPOINT=http://localhost:3000
