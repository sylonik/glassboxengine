{
  "name": "@glassbox/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:eval": "vitest run src/__tests__/recommendation-eval.test.ts",
    "eval:report": "node --import tsx/esm src/scripts/recommendation-eval-report.ts",
    "eval:report:sample": "node --import tsx/esm src/scripts/recommendation-eval-report.ts --dataset evals/sample-recommendation-eval.json --json-out ../../artifacts/recommendation-eval-sample.json",
    "eval:generate": "node --import tsx/esm src/scripts/generate-recommendation-eval-dataset.ts",
    "eval:export-feedback": "node --import tsx/esm src/scripts/export-feedback-eval-data.ts",
    "eval:convert-feedback-export": "node --import tsx/esm src/scripts/convert-feedback-export-to-eval-dataset.ts",
    "eval:run-feedback-export": "node --import tsx/esm src/scripts/run-feedback-export-eval.ts",
    "eval:run-feedback-export:sample": "node --import tsx/esm src/scripts/run-feedback-export-eval.ts --input evals/sample-feedback-export.json --out-dir ../../artifacts/recommendation-eval-from-export"
  },
  "dependencies": {
    "@google/adk": "^0.2.0",
    "@google/genai": "^1.0.0",
    "@glassbox/database": "workspace:*",
    "@glassbox/telemetry": "workspace:*",
    "drizzle-orm": "^0.41.0",
    "google-auth-library": "^10.6.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.20.6",
    "@glassbox/config": "workspace:*"
  }
}
