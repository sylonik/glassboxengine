# Database
DATABASE_URL="postgresql://user:password@localhost:5432/glassbox?schema=public"

# Authentication (better-auth)
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-here"
BETTER_AUTH_URL="http://localhost:3000"

# Google AI / ADK
GOOGLE_API_KEY="your-gemini-api-key"
GLASSBOX_USE_ADK="false"  # Set to "true" to use the in-process TypeScript @google/adk orchestration
ENABLE_TEST_AUTH="false"
# Embedding model (gemini-embedding-001; text-embedding-004 was retired). 768-dim to match products.embedding.
GLASSBOX_EMBEDDING_MODEL="gemini-embedding-001"

# Hybrid: Python ADK agent service (services/glassbox-agents on Vertex AI Agent Engine / Cloud Run).
# When set, the Mentor/Reasoner/Persona LLM steps delegate to this ADK service; unset = in-process @google/genai.
GLASSBOX_AGENT_SERVICE_URL=""        # e.g. http://localhost:8800 (local adk api_server) or the deployed service URL
GLASSBOX_AGENT_APP_NAME="app"
GLASSBOX_AGENT_SERVICE_TIMEOUT_MS="30000"

# OpenTelemetry
OTEL_SERVICE_NAME="glassbox-engine"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Event Pipeline — ClickHouse (OLAP event store)
CLICKHOUSE_URL="http://localhost:8123"
CLICKHOUSE_DATABASE="glassbox"

# Event Pipeline — Redis (BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Sentry (optional — error tracking)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
